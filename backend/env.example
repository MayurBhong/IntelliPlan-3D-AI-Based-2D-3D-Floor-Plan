# ═══════════════════════════════════════════════════════════════
# IntelliPlan·3D — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
#
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Flask ────────────────────────────────────────────────────────
FLASK_ENV=development          # development | testing | production
HOST=0.0.0.0
PORT=5000

# ── Security (change in production) ─────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=intelliplan-dev-secret-change-in-prod

# ── CORS origins (comma-separated) ──────────────────────────────
# Add your frontend URL in production
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,null

# ── GA Engine tuning (optional overrides) ───────────────────────
GA_POPULATION_SIZE=60
GA_MAX_GENERATIONS=50
GA_TOP_LAYOUTS=3

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                # DEBUG | INFO | WARNING | ERROR
